{
  "name": "ISPConfig",
  "version": "0.1.0",
  "description": "Manage ISPConfig servers: domains, mailboxes, databases, DNS records, websites, and system status.",
  "config": {
    "apiUrl": {
      "type": "string",
      "description": "ISPConfig Remote API URL (e.g. https://server:8080/remote/json.php)",
      "required": true
    },
    "username": {
      "type": "string",
      "description": "ISPConfig remote API username",
      "required": true
    },
    "password": {
      "type": "string",
      "description": "ISPConfig remote API password",
      "required": true,
      "secret": true
    },
    "readOnly": {
      "type": "boolean",
      "description": "If true, only read operations are allowed (list, get, DNS lookup)",
      "default": false
    },
    "allowedOperations": {
      "type": "array",
      "description": "Whitelist of allowed tool names. Empty = all allowed.",
      "items": { "type": "string" },
      "default": []
    },
    "verifySsl": {
      "type": "boolean",
      "description": "Verify SSL certificate of ISPConfig server",
      "default": true
    }
  },
  "tools": [
    "isp_sites_list",
    "isp_site_get",
    "isp_domains_list",
    "isp_domain_add",
    "isp_dns_zone_list",
    "isp_dns_record_list",
    "isp_dns_record_add",
    "isp_dns_record_delete",
    "isp_mail_domain_list",
    "isp_mail_user_list",
    "isp_mail_user_add",
    "isp_mail_user_delete",
    "isp_db_list",
    "isp_db_add",
    "isp_system_info"
  ]
}
